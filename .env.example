# ========================================
# X Automation - 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# ========================================

# ========================================
# Webhook URL（n8n等のオートメーションツール）
# ========================================
WEBHOOK_URL=https://your-domain.com/webhook/post-handler
REPLY_WEBHOOK_URL=https://your-domain.com/webhook/reply-handler
ARTICLE_WEBHOOK_URL=https://your-domain.com/webhook/article-handler
GIVEAWAY_WEBHOOK_URL=https://your-domain.com/webhook/giveaway-content

# ========================================
# X（Twitter）API
# https://developer.twitter.com でBearer Tokenを取得
# ========================================
X_BEARER_TOKEN=your_x_api_bearer_token_here

# ========================================
# SocialData API（X記事リサーチ用）
# https://socialdata.tools でAPIキーを取得
# ========================================
SOCIALDATA_API_KEY=your_socialdata_api_key_here

# ========================================
# Google AI / Gemini API（画像・動画生成）
# https://aistudio.google.com でAPIキーを取得
# ========================================
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ========================================
# Fish Audio API（音声生成、動画パイプライン用）
# https://fish.audio でAPIキーを取得
# ========================================
FISH_AUDIO_API_KEY=your_fish_audio_api_key_here
FISH_AUDIO_VOICE_ID=your_fish_audio_voice_id_here

# ========================================
# Google Cloud Storage（動画ファイル保存）
# ========================================
GCS_BUCKET_NAME=your_gcs_bucket_name_here
