          "value": {
            "data": {
              "markdown": "```bash\n#!/usr/bin/env bash\nset -euo pipefail\ngit add -A\nif ! git diff --cached --quiet; then\n  git commit -m \"chore(ai): apply Claude edit\"\nfi\nexit 0\n```"
