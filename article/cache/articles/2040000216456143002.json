            "data": {
              "markdown": "```json\n{\n  \"hooks\": {\n    \"PreToolUse\": [\n      {\n        \"matcher\": \"Bash\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \".claude/hooks/log-commands.sh\"\n          }\n        ]\n      }\n    ]\n  }\n}\n```"
            },
            "mutability": "Mutable",
            "type": "MARKDOWN"
