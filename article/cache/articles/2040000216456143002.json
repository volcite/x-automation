          "value": {
            "data": {
              "markdown": "```json\n{\n  \"hooks\": {\n    \"Stop\": [\n      {\n        \"matcher\": \"\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \".claude/hooks/auto-commit.sh\"\n          }\n        ]\n      }\n    ]\n  }\n}\n```"
            },
