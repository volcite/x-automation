                {
                  "localMediaId": "1",
                  "mediaCategory": "DraftTweetImage",
                  "mediaId": "2039983268309655552"
                }
              ]
            },
            "mutability": "Immutable",
            "type": "MEDIA"
          }
        },
        {
          "key": "4",
          "value": {
            "data": {
              "url": "https://code.claude.com/docs/en/hooks"
            },
            "mutability": "Mutable",
            "type": "LINK"
          }
        },
        {
          "key": "15",
          "value": {
            "data": {
              "markdown": "```bash\n#!/usr/bin/env bash\nset -euo pipefail\ncmd=$(jq -r '.tool_input.command // \"\"')\nprintf '%s %s\\n' \"$(date -Is)\" \"$cmd\" >> .claude/command-log.txt\nexit 0\n```"
            },
            "mutability": "Mutable",
            "type": "MARKDOWN"
          }
        },
        {
          "key": "11",
          "value": {
            "data": {
              "markdown": "```json\n{\n  \"hooks\": {\n    \"PostToolUse\": [\n      {\n        \"matcher\": \"Write|Edit\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \"npm run test --silent 2>&1 | tail -5; exit 0\"\n          }\n        ]\n      }\n    ]\n  }\n}\n```"
            },
            "mutability": "Mutable",
            "type": "MARKDOWN"
          }
        },
        {
          "key": "9",
          "value": {
            "data": {
              "markdown": "```bash\n#!/usr/bin/env bash\nset -euo pipefail\nfile=$(jq -r '.tool_input.file_path // .tool_input.path // \"\"')\n\nprotected=(\n  \".env*\"\n  \".git/*\"\n  \"package-lock.json\"\n  \"yarn.lock\"\n  \"*.pem\"\n  \"*.key\"\n  \"secrets/*\"\n)\n\nfor pattern in \"${protected[@]}\"; do\n  if echo \"$file\" | grep -qiE \"^${pattern//\\*/.*}$\"; then\n    echo \"Blocked: '$file' is protected. Explain why this edit is necessary.\" >&2\n    exit 2\n  fi\ndone\nexit 0\n```"
            },
            "mutability": "Mutable",
            "type": "MARKDOWN"
          }
        },
        {
          "key": "22",
          "value": {
            "data": {
              "entityKey": "cf4a9dc2-7ea2-4499-b032-00614094965a",
              "mediaItems": [
                {
                  "localMediaId": "3",
                  "mediaCategory": "DraftTweetImage",
                  "mediaId": "2039983798868185088"
                }
              ]
            },
            "mutability": "Immutable",
            "type": "MEDIA"
          }
        },
        {
