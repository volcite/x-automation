          "value": {
            "data": {
              "markdown": "```json\n{\n  \"hooks\": {\n    \"PreToolUse\": [\n      {\n        \"matcher\": \"mcp__github__create_pull_request\",\n        \"hooks\": [\n          {\n            \"type\": \"command\",\n            \"command\": \".claude/hooks/require-tests-for-pr.sh\"\n          }\n        ]\n      }\n    ]\n  }\n}\n```"
            },
            "mutability": "Mutable",
            "type": "MARKDOWN"
          }
        },
        {
