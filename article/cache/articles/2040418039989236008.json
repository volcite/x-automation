        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "6i1q5",
          "text": "The expected output",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "a6jjo",
          "text": "Examples:",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "f5b8h",
