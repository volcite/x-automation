        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [
            {
              "length": 36,
              "offset": 24,
              "style": "Bold"
            }
          ],
          "key": "f1n0f",
          "text": "Claw operates best with clear, outcome-oriented instructions.",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "bhm5l",
          "text": "Instead of vague prompts, define:",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "180jk",
          "text": "The objective",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "68sev",
          "text": "The context",
