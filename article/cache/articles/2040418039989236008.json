          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "do417",
          "text": "The clearer the intent, the more efficiently Claw executes.",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [
            {
              "length": 35,
              "offset": 0,
              "style": "Bold"
            }
          ],
          "key": "37ckm",
