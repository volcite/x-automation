          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "9rb0n",
          "text": "FP16 → ~140 GB",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "120io",
