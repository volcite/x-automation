          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "aa5nv",
          "text": "FP8 → ~405 GB",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "7nbls",
          "text": "4-bit → ~200+ GB",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "8phtn",
          "text": "Now you understand why people either:",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "827v3",
          "text": "quantize aggressively",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "dl940",
          "text": "shard across GPUs (e.g. Tensor Parallelism)",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "2stcv",
          "text": "or just give up and say “cloud it is”",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "19v5v",
          "text": "GPU Reality: What Actually Fits",
          "type": "header-two"
        },
        {
          "data": [],
          "entityRanges": [],
