          ],
          "inlineStyleRanges": [],
          "key": "1uu9k",
          "text": "📍所在地\n〒162-0067 東京都新宿区富久町1-6 1階\n買える化石博物館 TOKYO",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [
