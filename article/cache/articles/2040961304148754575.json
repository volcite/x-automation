          "inlineStyleRanges": [
            {
              "length": 8,
              "offset": 0,
              "style": "Bold"
            }
          ],
          "key": "emvhc",
          "text": "第一章 後篇\n\n※木〜日曜放映",
          "type": "unstyled"
