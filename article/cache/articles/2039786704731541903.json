        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "6dd2i",
          "text": "If you do it well, you’ll have something that feels personal, grounded, and increasingly excellent.",
          "type": "unstyled"
        },
        {
          "data": [],
