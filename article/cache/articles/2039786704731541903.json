          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "r18k",
          "text": "prepare the day proactively",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "61oj8",
          "text": "handle operational business-development workflows",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "bj4e4",
