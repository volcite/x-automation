              "style": "Bold"
            }
          ],
          "key": "c5gr2",
          "text": "This is where I keep environment-specific notes.",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "3g6ip",
          "text": "For example:",
