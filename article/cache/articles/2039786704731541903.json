              }
            ]
          },
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "9to83",
          "text": "I turned my @openclaw into the most effective assistant and chief of staff I’ve ever worked with.\n\nI’ve hired executive assistants in previous companies, and I’m honestly blown away by how well this works.\n\nIf you want the shortcut, start here:\nhttp://github.com/snarktank/clawchief",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [
            {
              "length": 14,
              "offset": 0,
              "style": "Bold"
            }
          ],
          "key": "9v3qi",
          "text": "What it can do",
          "type": "header-two"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "dr9g7",
          "text": "Schedule meetings for me",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "4mtcl",
          "text": "Parse booking links and book workable times",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "3js18",
          "text": "Check my inbox every 15 minutes and surface only what matters",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "405mn",
          "text": "Proactively follow up on emails that didn’t get a reply",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "7vf3p",
          "text": "Watch my calendar, flag conflicts, and warn me about upcoming events",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "3lgse",
          "text": "Run my day from one canonical markdown task list",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "2ehtn",
          "text": "Prep my task list before I wake up",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "cjb39",
          "text": "Keep tasks clean by avoiding duplicate entries",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "7mifa",
          "text": "Update my outreach tracker / CRM based on email activity",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "73sfv",
          "text": "Research suppliers or partners and reach out to them",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "78i4s",
          "text": "Send me short, high-signal updates only when action is needed",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "a438k",
          "text": "Work from durable context in files, memory, Gmail, Calendar, and Sheets",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "8h97i",
          "text": "Adapt to my business, my preferences, and my operating style",
          "type": "unordered-list-item"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "ts3v",
          "text": "Credit",
          "type": "header-two"
        },
        {
          "data": {
