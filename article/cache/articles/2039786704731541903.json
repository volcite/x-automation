        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [
            {
              "length": 7,
              "offset": 54,
              "style": "Bold"
            }
          ],
          "key": "6fgt3",
          "text": "That’s how you stop your assistant from being passive without turning it into a noisy mess.",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "cs4s4",
          "text": "Why TOOLS.md matters",
