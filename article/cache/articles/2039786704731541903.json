        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "dfa80",
          "text": "Why HEARTBEAT.md matters",
          "type": "header-two"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "4lf4i",
