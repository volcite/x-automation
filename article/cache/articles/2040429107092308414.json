              "style": "Bold"
            }
          ],
          "key": "v5qm",
          "text": "1回この方法で漫画描いてみてほしい",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [
            {
              "length": 10,
              "offset": 0,
              "style": "Bold"
            }
          ],
          "key": "17n06",
          "text": "ばちくそ楽しいから。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "fltqj",
          "text": "",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "fh636",
          "text": "これ10年前の俺がやってた。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "fv0tj",
          "text": "漫画描くの楽しくて仕方なかった時期。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "dpjkl",
          "text": "当時は資料見るの本当に嫌だったし、下描きするのも死ぬほど嫌だった。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "ordk",
          "text": "資料見るとかダサいと思ってたし（当時は）、",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "dk15b",
          "text": "1回描いたものをまたなぞるのかよ！？",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "2dgpj",
          "text": "正気か！？って思ってた。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "bi0ol",
          "text": "ネームも嫌だった。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "4idul",
          "text": "誰が読み返すんだよ！？このきたねえネーム！！",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "al99g",
          "text": "だからといって綺麗には描けなかった。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "30imn",
          "text": "だったらいきなり本番を描けばいいだろ！！！！",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "evdai",
          "text": "",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "52hmi",
          "text": "1コマ1コマ考えながら本番描いてた。これがねえ　楽しいんだあ",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "7f50j",
          "text": "完成したものがどうなるか全く分からなくて、",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "55cu5",
          "text": "ワクワクした。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "5ik2d",
          "text": "だって描きながら考えてるからね。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "6a7g0",
          "text": "世紀のクソ漫画になる可能性が高いけど、",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "5fqvq",
          "text": "たまーにいい漫画も生まれるからたまらない。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "5higv",
          "text": "というかクソ漫画でもいい。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "dqg4u",
          "text": "神漫画じゃなきゃだめぇ？そんなもん描ける訳ないだろ。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "8ksor",
          "text": "何より、描いてる間めっちゃ楽しい。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "1kjj1",
          "text": "だってボツにしないから。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "7t8i0",
          "text": "全部採用するんだからそら楽しいわ。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "fiujm",
          "text": "「ここ棒立ちじゃなくてポーズ付けたいな・・・描き直すか。」",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "323mp",
          "text": "描き直しません。めんどくさいから。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "ahrom",
          "text": "というか、せっかく描いたもんを消すって正気ですか？ホトチンコスープさん。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "f9so9",
          "text": "で、完成したらお蔵入りにしない。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "4har7",
          "text": "絶対に公開する。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "4r0lh",
          "text": "超くそ電波黒歴史確定漫画でも公開する。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "2uq04",
          "text": "自由には責任が伴う。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "529q8",
          "text": "これがねえ　気持ちいいんだ。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "aphte",
          "text": "俺の全てを見て・・・。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "1f4u6",
          "text": "みんなもクソ漫画を描いて気持ち良くなろう。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "5c9v0",
          "text": "漫画の面倒くさい部分を全部サボろう。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "6bejb",
          "text": "よく考えたら、下描きとか描きたくないよな。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "7hhi9",
          "text": "ネームも描きたくねえし、乳首しか描きたくないよな。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "19nie",
          "text": "社会不適合者だから漫画描いてんのに、",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "58eed",
          "text": "ネームなんか描けるわけないだろ",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "btgeo",
          "text": "あー幸子と結婚したい",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "c8knd",
          "text": "うそ。",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "5om3r",
          "text": "",
