          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "1fkkg",
          "text": "━━━━━━━━━━━━━━",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [],
          "key": "8s2ba",
          "text": "ここからが本題。Xのアルゴリズム、何が変わったのか？",
