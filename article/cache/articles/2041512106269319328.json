        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [
            {
              "length": 6,
              "offset": 0,
              "style": "Bold"
            }
          ],
          "key": "5rgk",
          "text": "Step 2: Download Gemma 4 26B A4B to your machine. That model is both capable and fast, so an excellent choice for running local Agents. You can also skip this step, as Step 3 takes care of the whole thing.",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [
            {
              "key": 3,
              "length": 1,
              "offset": 0
            }
          ],
          "inlineStyleRanges": [],
          "key": "14avi",
