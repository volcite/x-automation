              "length": 6,
              "offset": 0,
              "style": "Bold"
            }
          ],
          "key": "8coda",
          "text": "Step 1: Install Ollama from https://ollama.com/download",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [
            {
              "key": 2,
              "length": 1,
              "offset": 0
            }
          ],
