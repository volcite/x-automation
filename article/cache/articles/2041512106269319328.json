          "type": "atomic"
        },
        {
          "data": [],
          "entityRanges": [],
          "inlineStyleRanges": [
            {
              "length": 6,
              "offset": 0,
              "style": "Bold"
            }
          ],
          "key": "4pppm",
          "text": "Step 3: Launch OpenClaw with Gemma 4 as the backend via Ollama. This will automatically install OpenClaw on your system and launch it with Gemma 4 26B A4B.",
          "type": "unstyled"
        },
        {
          "data": [],
          "entityRanges": [
            {
              "key": 4,
