                  "mediaId": "2039302810647625728"
                }
              ]
            },
            "mutability": "Immutable",
            "type": "MEDIA"
          }
        },
        {
          "key": "5",
          "value": {
            "data": {
              "entityKey": "2d240440-da98-4718-b0e1-96064936950b",
              "markdown": "```\n# macOS の場合\nls -la ~/Library/Caches/com.apple.act.mond\n\n# Windows の場合\nls %PROGRAMDATA%\\wt.exe\n\n# Linux の場合\nls -la /tmp/ld.py\n```"
            },
            "mutability": "Mutable",
            "type": "MARKDOWN"
          }
        },
        {
          "key": "10",
          "value": {
            "data": {
              "entityKey": "4e747074-6f4d-40f2-b738-f1b5c60b2855",
              "markdown": "```\n# 公開から7日以内のパッケージはインストールしない設定\nmin-release-age=7\n```"
            },
            "mutability": "Mutable",
            "type": "MARKDOWN"
          }
        },
        {
          "key": "6",
          "value": {
            "data": {
              "entityKey": "1d7f5de6-4ae6-4156-8edb-951b9325aaec",
              "markdown": "```\n# 現在のバージョンを確認する\nclaude --version\n```"
            },
            "mutability": "Mutable",
            "type": "MARKDOWN"
          }
        },
        {
