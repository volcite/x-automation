            "type": "MEDIA"
          }
        },
        {
          "key": "9",
          "value": {
            "data": {
              "entityKey": "8351e24f-d25f-471e-83d4-bf10663f1228",
              "markdown": "```\n# インストール時にlockfileを厳守する\nnpm ci                          # 推奨\nyarn install --frozen-lockfile  # yarn使用者向け\npnpm install --frozen-lockfile  # pnpm使用者向け\n```"
            },
            "mutability": "Mutable",
            "type": "MARKDOWN"
          }
        },
        {
          "key": "13",
          "value": {
            "data": {
              "entityKey": "e7d7bad4-adf0-40b8-bfe7-0d8531642a5b",
              "mediaItems": [
                {
                  "localMediaId": "3",
